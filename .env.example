# =============================================================================
# alloyium — example environment. Copy to `.env` and edit:  cp .env.example .env
#
# Every value below has a sensible default baked into compose.yaml, so a plain
# `docker compose up` works with NO .env at all. Override here only what you need.
# NEVER commit your real `.env` (it is gitignored). No secrets are shipped here.
# =============================================================================

# -----------------------------------------------------------------------------
# Core message bus + cache (compose service DNS by default — no LAN assumptions)
# -----------------------------------------------------------------------------
# Point these at an EXTERNAL bus to skip the bundled nats/redis containers.
NATS_URL=nats://nats:4222
REDIS_URL=redis://redis:6379
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Your own model / LLM credentials  (bring your own — nothing is baked in)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY enables the portal's optional LangChain assistant. Leave blank
# to disable that feature gracefully (the rest of the stack runs without it).
OPENAI_API_KEY=
# Optional: override the model the portal assistant uses.
# A2A_PORTAL_LANGCHAIN_MODEL=gpt-4o-mini

# The Claude Code gateway does NOT use an API key — it drives your logged-in `claude`
# CLI session (OAuth subscription) and explicitly strips ANTHROPIC_API_KEY from the child.
# Leave this blank; it is here only for unrelated tools that may read it.
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Portal (core path) — the web UI / channel viewer
# -----------------------------------------------------------------------------
A2A_PORTAL_BIND=127.0.0.1          # host interface to publish the portal on
A2A_PORTAL_HOST_PORT=8901          # host port -> container 8900
A2A_PORTAL_AGENT_ID=a2a-portal
A2A_PORTAL_SEND_ENABLED=1
A2A_MAX_SEND_BYTES=8192

# -----------------------------------------------------------------------------
# a2a-core (core path)
# -----------------------------------------------------------------------------
# Where the inbox sqlite + core UDS socket live on the host (repo-relative defaults).
A2A_INBOX_HOST_PATH=./data/a2a-inbox
A2A_CORE_RUN_HOST_PATH=/run/a2a-core
A2A_CORE_BEAT_MS=0

# -----------------------------------------------------------------------------
# OPTIONAL external integrations — leave BLANK to disable (no-op / fail-soft).
# Set only if you run your OWN brain / kai / taskboard services. Examples:
#   BRAIN_URL=http://your-brain-host:8787
#   KAI_HTTP_URL=http://your-kai-host:18789
#   KAI_WS_URL=ws://your-kai-host:18789/ws
#   TASKBOARD_URL=http://your-taskboard-host:18180
# -----------------------------------------------------------------------------
BRAIN_URL=
KAI_HTTP_URL=
KAI_WS_URL=
KAI_TOKEN_PATH=
TASKBOARD_URL=
TASKBOARD_API_TOKEN=

# -----------------------------------------------------------------------------
# Codex gateway  (real agent — starts by default with `docker compose up`)
# Uses YOUR own codex/model auth + SSH keys mounted at runtime — none are baked in.
# Log in once on the host with the `codex` CLI; the gateway reuses that session.
# -----------------------------------------------------------------------------
CODEX_CLI_VERSION=0.141.0
CODEX_GW_AGENT_ID=codex-gw
CODEX_GW_MODEL=                    # blank = codex CLI default
CODEX_GW_EFFORT=xhigh
# These default to your host ~/.codex, ~/.ssh and ~/git (compose expands ${HOME}).
# Uncomment + set ONLY to override with an absolute path:
# CODEX_HOST_HOME=/abs/path/to/.codex      # your codex auth -> container ~/.codex
# CODEX_SSH_DIR=/abs/path/to/.ssh          # your SSH keys for git push (read-only)
# CODEX_WORKSPACE_ROOT=/abs/path/to/git    # host workspace root codex can read/write
# Container user/group ids (match your host user to keep mounted-file ownership sane).
# Shared with the Claude Code gateway below.
CC_UID=1000
CC_GID=1000

# -----------------------------------------------------------------------------
# Claude Code gateway  (real agent — starts by default with `docker compose up`)
# Drives YOUR own logged-in `claude` CLI session mounted at runtime — NO API key.
# The gateway strips ANTHROPIC_API_KEY / ANTHROPIC_AUTH_TOKEN from the child: it runs
# on your OAuth subscription only. Log in once on the host with the `claude` CLI first.
# -----------------------------------------------------------------------------
CLAUDE_CLI_VERSION=2.1.177
CLAUDE_GW_AGENT_ID=claude-gw
CLAUDE_GW_MODEL=opus               # claude CLI model alias (e.g. opus, sonnet)
CLAUDE_GW_EFFORT=high              # low | medium | high | xhigh | max
# CLAUDE_GW_POOL=2                  # warm idle sessions kept ready for no-thread-key jobs
# CLAUDE_GW_CWD=/tmp               # clean inference cwd (no project CLAUDE.md/settings bleed)
# These default to your host ~/.claude, ~/.claude.json and ~/.ssh (compose expands ${HOME}).
# Uncomment + set ONLY to override with an absolute path:
# CLAUDE_HOST_HOME=/abs/path/to/.claude         # your claude login dir  -> container ~/.claude
# CLAUDE_HOST_CONFIG=/abs/path/to/.claude.json  # your claude config/login -> container ~/.claude.json
# CLAUDE_SSH_DIR=/abs/path/to/.ssh              # your SSH keys (read-only)
# (CC_UID / CC_GID above are shared with this gateway.)

# -----------------------------------------------------------------------------
# Launcher  (opt-in:  docker compose --profile launcher up)
# -----------------------------------------------------------------------------
A2A_LAUNCHER_HOST=0.0.0.0
# A2A_LAUNCH_CODEX_IMAGE=alloyium-codex-gw:latest
# A2A_LAUNCH_CLAUDE_IMAGE=alloyium-claude-gw:latest
# A2A_LAUNCH_NETWORK=alloyium_a2a-net
# A2A_LAUNCH_SECRETS_VOLUME=alloyium_a2a_secrets
# The launcher spawns kind=claude / kind=codex workers that reuse your host CLI login:
# it reads CLAUDE_HOST_HOME + CLAUDE_HOST_CONFIG (and CODEX_HOST_HOME) from the gateway
# sections above to bind ~/.claude + ~/.claude.json (or ~/.codex) into each new worker.

# -----------------------------------------------------------------------------
# Taskboard bridge / dispatcher  (opt-in:  docker compose --profile taskboard up)
# -----------------------------------------------------------------------------
TASKBOARD_EVENT_BRIDGE_BIND=127.0.0.1
TASKBOARD_EVENT_BRIDGE_HOST_PORT=18889
TASKBOARD_EVENT_BRIDGE_HMAC_SECRET=
# Optional env-file of review tokens (absent file is fine):
# TASKBOARD_REVIEW_TOKENS_ENV=./secrets/taskboard-review-tokens.env

# -----------------------------------------------------------------------------
# Kai token materializer  (opt-in:  --profile kai) — needs your own vault tokens file
# -----------------------------------------------------------------------------
# KAI_VAULT_TOKENS_FILE=./secrets/vault-tokens.json

# -----------------------------------------------------------------------------
# Legacy bus proxies (opt-in: --profile remote-bus / --profile legacy-nats-proxy)
# Expose the in-compose bus on a host interface for remote agents.
# -----------------------------------------------------------------------------
A2A_REMOTE_BUS_BIND=127.0.0.1
A2A_REMOTE_NATS_PORT=4222
A2A_REMOTE_REDIS_PORT=16379
